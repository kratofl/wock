@inherits LayoutComponentBase
@implements IDisposable
@inject ThemePreferenceService ThemePreferences

<MudThemeProvider Theme="@WockTheme.Theme" IsDarkMode="_isDarkMode" ObserveSystemDarkModeChange="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@LayoutCssClass">
    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Mini" ClipMode="DrawerClipMode.Never" Elevation="0" Class="wock-drawer" Width="14.5rem" MiniWidth="3.5rem">
        <div class="wock-sidebar-header">
            <div class="wock-shell-brand">
                <span class="wock-brand-mark" aria-hidden="true"></span>
                <div class="wock-shell-copy">
                    <MudText Typo="Typo.h6">Wock</MudText>
                    <MudText Typo="Typo.caption" Class="wock-shell-subtitle">Work tracking dashboard</MudText>
                </div>
            </div>
            <button type="button" class="wock-icon-button wock-sidebar-toggle" @onclick="ToggleDrawer" aria-label="Toggle navigation">
                <i class="fa-solid fa-bars wock-icon" aria-hidden="true"></i>
            </button>
        </div>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="wock-main-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    private string LayoutCssClass => _isDarkMode
        ? "wock-layout wock-layout-dark"
        : "wock-layout";

    protected override void OnInitialized()
    {
        ThemePreferences.Changed += ThemePreferenceChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ThemePreferences.LoadAsync();
        _isDarkMode = ThemePreferences.IsDarkMode;
        StateHasChanged();
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ThemePreferenceChanged()
    {
        _isDarkMode = ThemePreferences.IsDarkMode;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemePreferences.Changed -= ThemePreferenceChanged;
    }
}
