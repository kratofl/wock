@page "/plugins"
@using Microsoft.AspNetCore.Components.Forms
@using Wock.Models
@inject PluginRegistryService PluginRegistry

<MudStack Spacing="3" Class="wock-page-stack">
    <MudText Typo="Typo.h3">Plugins</MudText>

    <StatusMessage Message="@_message" Kind="@_messageSeverity" />

    <MudPaper Elevation="0" Class="wock-section">
        <EditForm Model="_installModel" OnValidSubmit="InstallAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudStack Spacing="2">
                <MudText Typo="Typo.h5">Install from folder</MudText>
                <MudTextField T="string" Label="Plugin folder" HelperText="@($"Folder must contain {PluginManifest.FileName}.")" @bind-Value="_installModel.PluginFolderPath" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Install from folder</MudButton>
            </MudStack>
        </EditForm>
    </MudPaper>

    <MudPaper Elevation="0" Class="wock-section">
        <EditForm Model="_installModel" OnValidSubmit="InstallZipAsync">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h5">Install from ZIP</MudText>
                <MudTextField T="string" Label="Plugin ZIP" HelperText="@($"ZIP archive must contain {PluginManifest.FileName} and must not contain path traversal entries.")" @bind-Value="_installModel.PluginZipPath" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Install from ZIP</MudButton>
            </MudStack>
        </EditForm>
    </MudPaper>

    <MudTable Items="_plugins" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Enabled</MudTh>
            <MudTh>Last error</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate Context="plugin">
            <MudTd DataLabel="Name">@plugin.Name</MudTd>
            <MudTd DataLabel="Version">@plugin.Version</MudTd>
            <MudTd DataLabel="Status">@plugin.LastLoadStatus</MudTd>
            <MudTd DataLabel="Enabled">@plugin.IsEnabled</MudTd>
            <MudTd DataLabel="Last error">@plugin.LastLoadError</MudTd>
            <MudTd>
                @if (plugin.IsEnabled)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="() => SetEnabledAsync(plugin.Id, false)">Disable</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="() => SetEnabledAsync(plugin.Id, true)">Enable</MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private readonly InstallModel _installModel = new();
    private IReadOnlyList<InstalledPlugin> _plugins = [];
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task InstallAsync()
    {
        try
        {
            await PluginRegistry.InstallFromFolderAsync(_installModel.PluginFolderPath);
            _installModel.PluginFolderPath = string.Empty;
            _message = "Plugin installed.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task InstallZipAsync()
    {
        try
        {
            await PluginRegistry.InstallFromZipAsync(_installModel.PluginZipPath);
            _installModel.PluginZipPath = string.Empty;
            _message = "Plugin installed.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task SetEnabledAsync(int pluginId, bool isEnabled)
    {
        try
        {
            var plugin = await PluginRegistry.SetEnabledAsync(pluginId, isEnabled);
            if (isEnabled && plugin.IsEnabled)
            {
                _message = "Plugin enabled.";
                _messageSeverity = Severity.Success;
            }
            else if (isEnabled)
            {
                _message = "Plugin could not be enabled.";
                _messageSeverity = Severity.Warning;
            }
            else
            {
                _message = "Plugin disabled.";
                _messageSeverity = Severity.Success;
            }
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _plugins = await PluginRegistry.ListAsync();
    }

    private sealed class InstallModel
    {
        public string PluginFolderPath { get; set; } = string.Empty;

        public string PluginZipPath { get; set; } = string.Empty;
    }
}
