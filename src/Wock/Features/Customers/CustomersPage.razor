@page "/customers"
@using Wock.Models
@inject CustomerService CustomerService

<MudStack Spacing="3" Class="wock-page-stack">
    <MudText Typo="Typo.h3">Customers</MudText>

    <StatusMessage Message="@_message" Kind="@_messageSeverity" />

    <MudPaper Elevation="0" Class="wock-section">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Create customer</MudText>
            <MudTextField T="string" Label="Name" @bind-Value="_newCustomer.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudTextField T="string" Label="Notes" Lines="3" @bind-Value="_newCustomer.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync">Create customer</MudButton>
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.h5">Active customers</MudText>

    @if (_customers.Count == 0)
    {
        <MudText>No active customers.</MudText>
    }
    else
    {
        <MudTable Items="_customers" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Notes</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate Context="customer">
                @{
                    var model = _editModels[customer.Id];
                }
                <MudTd DataLabel="Name">
                    <MudTextField T="string" aria-label="Customer name" @bind-Value="model.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Notes">
                    <MudTextField T="string" aria-label="Customer notes" @bind-Value="model.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudTd>
                <MudTd>
                    <div class="wock-button-row">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="() => UpdateAsync(customer.Id)">Save</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeactivateAsync(customer.Id)">Deactivate</MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

@code {
    private readonly CustomerFormModel _newCustomer = new();
    private readonly Dictionary<int, CustomerFormModel> _editModels = [];
    private IReadOnlyList<Customer> _customers = [];
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task CreateAsync()
    {
        try
        {
            await CustomerService.CreateAsync(_newCustomer.Name, _newCustomer.Notes);
            _newCustomer.Name = string.Empty;
            _newCustomer.Notes = string.Empty;
            _message = "Customer created.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task UpdateAsync(int customerId)
    {
        try
        {
            var model = _editModels[customerId];
            await CustomerService.UpdateAsync(customerId, model.Name, model.Notes);
            _message = "Customer updated.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task DeactivateAsync(int customerId)
    {
        try
        {
            await CustomerService.DeactivateAsync(customerId);
            _message = "Customer deactivated.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _customers = await CustomerService.ListActiveAsync();
        _editModels.Clear();
        foreach (var customer in _customers)
        {
            _editModels[customer.Id] = new CustomerFormModel
            {
                Name = customer.Name,
                Notes = customer.Notes ?? string.Empty
            };
        }
    }

    private sealed class CustomerFormModel
    {
        public string Name { get; set; } = string.Empty;

        public string Notes { get; set; } = string.Empty;
    }
}
