@page "/"
@page "/time-tracking"
@using Microsoft.EntityFrameworkCore
@using Wock.Common.Time
@using Wock.Components.Theme
@using Wock.Data
@using Wock.Features.TimeTracking.Components
@using Wock.Models
@implements IAsyncDisposable
@inject TimeTrackingService TimeTracking
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject ISystemClock Clock

<MudStack Spacing="3" Class="wock-page-stack wock-dashboard-page">
    <MudPaper Elevation="0" Class="wock-dashboard-hero">
        <MudStack Spacing="1">
            <MudText Typo="Typo.overline" Class="wock-page-kicker">Arbeitszeit</MudText>
            <MudText Typo="Typo.h3" Class="wock-page-title">Zeit fuer Kunden erfassen</MudText>
            <MudText Typo="Typo.body1" Class="wock-muted">Kunde auswaehlen, optional Projekt und Taetigkeit ergaenzen, starten.</MudText>
        </MudStack>
    </MudPaper>

    <StatusMessage Message="@_message" Kind="@_messageSeverity" />

    <MudGrid Spacing="3" Class="wock-dashboard-panels">
        <MudItem xs="12" lg="7" Class="wock-dashboard-panel">
            @if (_activeEntry is null)
            {
                <MudPaper Elevation="0" Outlined="true" Class="wock-section wock-custom-start-panel">
                    <MudStack Spacing="2">
                        <div class="wock-section-heading">
                            <div>
                                <MudText Typo="Typo.h5">Zeit starten</MudText>
                                <MudText Typo="Typo.body2" Class="wock-muted">Customer first: Projekt, Aufgabe, Kategorie und Ticket koennen ergaenzt werden.</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Draft</MudChip>
                        </div>
                        <WorkEntryForm Customers="_customers"
                                       BookingTargets="_bookingTargets"
                                       Projects="_projects"
                                       ProjectTasks="_projectTasks"
                                       ActivityCategories="_activityCategories"
                                       Disabled="_isBusy"
                                       OnStart="StartAsync" />
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <ActiveTimerCard Entry="_activeEntry" NetDuration="_netDuration" Disabled="_isBusy" OnPause="PauseAsync" OnResume="ResumeAsync" OnStop="StopAsync" />
            }
        </MudItem>

        <MudItem xs="12" lg="5" Class="wock-dashboard-panel">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="wock-metric-card">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.overline" Class="wock-metric-label">Today tracked</MudText>
                            <MudText Typo="Typo.h5" Class="wock-metric-value">@FormatDuration(_todayDuration)</MudText>
                            <MudText Typo="Typo.body2" Class="wock-muted">@_todayEntryCount entries today</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="wock-metric-card">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.overline" Class="wock-metric-label">This week</MudText>
                            <MudText Typo="Typo.h5" Class="wock-metric-value">@FormatDuration(_weekDuration)</MudText>
                            <MudText Typo="Typo.body2" Class="wock-muted">@_quickTasks.Count presets ready</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Outlined="true" Class="wock-section wock-quick-switch mt-3">
                <MudStack Spacing="2">
                    <div class="wock-section-heading">
                        <div>
                            <MudText Typo="Typo.h5">Zuletzt genutzt</MudText>
                            <MudText Typo="Typo.body2" Class="wock-muted">Ein Klick startet oder wechselt zu einer bekannten Kundenarbeit.</MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_quickTasks.Count ready</MudChip>
                    </div>

                    @if (_quickTasks.Count > 4)
                    {
                        <MudTextField T="string" Label="Search customer or preset" @bind-Value="_taskSearch" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    }

                    @if (_quickTasks.Count == 0)
                    {
                        <MudPaper Elevation="0" Outlined="true" Class="wock-empty-state">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.h6">No presets ready yet</MudText>
                                <MudText Typo="Typo.body2" Class="wock-muted">Start once for a customer or create customer work in master data, then it appears here.</MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="booking-targets">Create presets</MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        var visibleTasks = VisibleQuickTasks;
                        @if (visibleTasks.Count == 0)
                        {
                            <MudText Class="wock-muted">No tasks match the current search.</MudText>
                        }
                        else
                        {
                            <div class="wock-quick-task-list">
                                @foreach (var task in visibleTasks)
                                {
                                    <MudButton Variant="@GetQuickTaskVariant(task)" Color="@GetQuickTaskColor(task)" FullWidth="true" Disabled="_isBusy" Class="@GetQuickTaskClass(task)" OnClick="() => ActivateTaskAsync(task.Id)">
                                        <span class="wock-quick-task-content">
                                            <span class="wock-quick-task-main">
                                                <span class="wock-quick-task-title">@task.Name</span>
                                                <span class="wock-quick-task-meta">@FormatTaskMeta(task)</span>
                                            </span>
                                            <span class="wock-quick-task-side">
                                                <span class="wock-quick-task-duration">@FormatDuration(task.TodayDuration)</span>
                                                <span class="wock-quick-task-action">@GetTaskActionLabel(task)</span>
                                            </span>
                                        </span>
                                    </MudButton>
                                }
                            </div>
                        }

                        @if (HasHiddenQuickTasks)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ShowAllTasks">Show all tasks</MudButton>
                        }
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Outlined="true" Class="wock-section">
        <MudStack Spacing="2">
            <div class="wock-section-heading">
                <div>
                    <MudText Typo="Typo.h5">Heute</MudText>
                    <MudText Typo="Typo.body2" Class="wock-muted">Laufende und gestoppte Eintraege mit Status und Nettozeit.</MudText>
                </div>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@FormatDuration(_todayDuration)</MudChip>
            </div>
            <MudTable Items="_todayEntries" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Status</MudTh>
                    <MudTh>Customer</MudTh>
                    <MudTh>Work</MudTh>
                    <MudTh>Time</MudTh>
                    <MudTh>Net</MudTh>
                    <MudTh>Billing</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Status">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Status</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.ReviewStatus</MudChip>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Customer">@context.Customer?.Name</MudTd>
                    <MudTd DataLabel="Work">@FormatEntryWork(context)</MudTd>
                    <MudTd DataLabel="Time">@FormatEntryTime(context)</MudTd>
                    <MudTd DataLabel="Net">@FormatDuration(TimeTracking.GetNetDuration(context, Clock.UtcNow))</MudTd>
                    <MudTd DataLabel="Billing">@(context.IsBillable ? "Billable" : "Non-billable")</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No work entries tracked today.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private const int QuickTaskPreviewLimit = 12;

    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<BookingTarget> _bookingTargets = [];
    private IReadOnlyList<Project> _projects = [];
    private IReadOnlyList<ProjectTask> _projectTasks = [];
    private IReadOnlyList<ActivityCategory> _activityCategories = [];
    private IReadOnlyList<QuickTaskItem> _quickTasks = [];
    private IReadOnlyList<WorkEntry> _weekEntries = [];
    private IReadOnlyList<WorkEntry> _todayEntries = [];
    private string[] _weekChartLabels = [];
    private List<ChartSeries<double>> _weekChartSeries = [];
    private IReadOnlyDictionary<int, TimeSpan> _todayDurationsByTask = new Dictionary<int, TimeSpan>();
    private WorkEntry? _activeEntry;
    private TimeSpan _netDuration;
    private TimeSpan _todayDuration;
    private TimeSpan _weekDuration;
    private DateTime _todayStart;
    private DateTime _weekStart;
    private int _todayEntryCount;
    private string? _taskSearch;
    private bool _showAllTasks;
    private bool _isBusy;
    private string? _message;
    private Severity _messageSeverity = Severity.Error;
    private CancellationTokenSource? _liveRefreshCancellation;
    private Task? _liveRefreshTask;
    private readonly BarChartOptions _weekChartOptions = new()
    {
        ChartPalette = [WockTheme.ChartAccent],
        ShowLegend = false,
        TooltipTitleFormat = "{{X_VALUE}}",
        YAxisTicks = 15,
        YAxisSuggestedMax = 15,
        MaxNumYAxisTicks = 5,
        YAxisFormat = "0",
    };

    private IReadOnlyList<QuickTaskItem> FilteredQuickTasks
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_taskSearch))
            {
                return _quickTasks;
            }

            var search = _taskSearch.Trim();
            return _quickTasks
                .Where(task => task.Matches(search))
                .ToList();
        }
    }

    private IReadOnlyList<QuickTaskItem> VisibleQuickTasks
    {
        get
        {
            var tasks = FilteredQuickTasks;
            if (_showAllTasks || !string.IsNullOrWhiteSpace(_taskSearch))
            {
                return tasks;
            }

            return tasks
                .Take(QuickTaskPreviewLimit)
                .ToList();
        }
    }

    private bool HasHiddenQuickTasks => string.IsNullOrWhiteSpace(_taskSearch)
        && !_showAllTasks
        && _quickTasks.Count > QuickTaskPreviewLimit;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        StartLiveRefresh();
    }

    private async Task StartAsync(StartWorkEntryRequest request)
    {
        await RunAndRefreshAsync(() => TimeTracking.StartAsync(
            request.CustomerId,
            request.BookingTargetId,
            request.ExternalTicketId,
            request.Description,
            request.ProjectId,
            request.ProjectTaskId,
            request.ActivityCategoryId,
            request.IsBillable));
    }

    private async Task ActivateTaskAsync(int bookingTargetId)
    {
        await RunAndRefreshAsync(() => TimeTracking.SwitchToBookingTargetAsync(bookingTargetId));
    }

    private async Task PauseAsync()
    {
        await RunAndRefreshAsync(() => TimeTracking.PauseAsync());
    }

    private async Task ResumeAsync()
    {
        await RunAndRefreshAsync(() => TimeTracking.ResumeAsync());
    }

    private async Task StopAsync()
    {
        await RunAndRefreshAsync(() => TimeTracking.StopAsync());
    }

    private async Task RunAndRefreshAsync(Func<Task<WorkEntry>> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        try
        {
            await action();
            _message = null;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        try
        {
            await RefreshAsync();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RefreshAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        _customers = await context.Customers
            .AsNoTracking()
            .Where(customer => customer.IsActive)
            .OrderBy(customer => customer.Name)
            .ToListAsync();
        _bookingTargets = await context.BookingTargets
            .AsNoTracking()
            .Include(target => target.Customer)
            .Where(target => target.IsActive && target.Customer.IsActive)
            .OrderBy(target => target.Customer.Name)
            .ThenBy(target => target.Name)
            .ToListAsync();
        _projects = await context.Projects
            .AsNoTracking()
            .Include(project => project.Customer)
            .Where(project => project.Status != ProjectStatus.Archived && project.Customer.IsActive)
            .OrderBy(project => project.Customer.Name)
            .ThenBy(project => project.Name)
            .ToListAsync();
        _projectTasks = await context.ProjectTasks
            .AsNoTracking()
            .Include(task => task.Project)
            .Where(task => task.Status != ProjectTaskStatus.Archived && task.Project.Status != ProjectStatus.Archived)
            .OrderBy(task => task.Project.Name)
            .ThenBy(task => task.Title)
            .ToListAsync();
        _activityCategories = await context.ActivityCategories
            .AsNoTracking()
            .Where(category => category.IsActive)
            .OrderBy(category => category.SortOrder)
            .ThenBy(category => category.Name)
            .ToListAsync();

        _activeEntry = await TimeTracking.GetActiveEntryAsync();
        _netDuration = _activeEntry is null ? TimeSpan.Zero : TimeTracking.GetNetDuration(_activeEntry);
        await RefreshMetricsAsync(context);
        await RefreshQuickTasksAsync(context);
    }

    private async Task RefreshMetricsAsync(AppDbContext context)
    {
        var now = Clock.UtcNow;
        _todayStart = now.Date;
        _weekStart = GetStartOfWeek(_todayStart);
        var weekEnd = _weekStart.AddDays(7);
        _weekEntries = await context.WorkEntries
            .AsNoTracking()
            .Include(entry => entry.Customer)
            .Include(entry => entry.BookingTarget)
            .Include(entry => entry.Project)
            .Include(entry => entry.ProjectTask)
            .Include(entry => entry.ActivityCategory)
            .Include(entry => entry.Pauses)
            .Where(entry => entry.StartedAt >= _weekStart && entry.StartedAt < weekEnd)
            .OrderByDescending(entry => entry.StartedAt)
            .ToListAsync();
        _todayEntries = _weekEntries
            .Where(entry => entry.StartedAt >= _todayStart)
            .ToList();

        _todayEntryCount = _todayEntries.Count;
        _weekChartLabels = Enumerable.Range(0, 7)
            .Select(index => FormatDayLabel(_weekStart.AddDays(index)))
            .ToArray();
        RefreshLiveDurations(now);
    }

    private void RefreshLiveDurations(DateTime now)
    {
        _netDuration = _activeEntry is null ? TimeSpan.Zero : TimeTracking.GetNetDuration(_activeEntry, now);
        _todayDuration = SumNetDuration(_todayEntries, now);
        _weekDuration = SumNetDuration(_weekEntries, now);
        _todayDurationsByTask = _todayEntries
            .Where(entry => entry.BookingTargetId.HasValue)
            .GroupBy(entry => entry.BookingTargetId!.Value)
            .ToDictionary(group => group.Key, group => SumNetDuration(group, now));
        if (_quickTasks.Count > 0)
        {
            _quickTasks = _quickTasks
                .Select(task => task with
                {
                    TodayDuration = _todayDurationsByTask.TryGetValue(task.Id, out var todayDuration)
                        ? todayDuration
                        : TimeSpan.Zero
                })
                .ToList();
        }

        RefreshWeekChartSeries(now);
    }

    private void RefreshWeekChartSeries(DateTime now)
    {
        var dailyDurations = Enumerable.Range(0, 7)
            .Select(index => SumNetDuration(_weekEntries.Where(entry => entry.StartedAt.Date == _weekStart.AddDays(index)), now))
            .ToArray();
        _weekChartSeries =
        [
            new ChartSeries<double>
            {
                Name = "Tracked minutes",
                Data = dailyDurations.Select(duration => Math.Round(duration.TotalMinutes, 1)).ToArray(),
                TooltipYValueFormat = "0.# min",
            },
        ];
    }

    private async Task RefreshQuickTasksAsync(AppDbContext context)
    {
        var lastStartsByTask = await context.WorkEntries
            .AsNoTracking()
            .Where(entry => entry.BookingTargetId.HasValue)
            .GroupBy(entry => entry.BookingTargetId!.Value)
            .Select(group => new
            {
                BookingTargetId = group.Key,
                LastStartedAt = group.Max(entry => entry.StartedAt)
            })
            .ToDictionaryAsync(item => item.BookingTargetId, item => item.LastStartedAt);

        _quickTasks = _bookingTargets
            .Select(target =>
            {
                lastStartsByTask.TryGetValue(target.Id, out var lastStartedAt);
                _todayDurationsByTask.TryGetValue(target.Id, out var todayDuration);
                var isActive = _activeEntry?.BookingTargetId == target.Id;

                return new QuickTaskItem(
                    target.Id,
                    target.Customer.Name,
                    target.Name,
                    target.BookingSoftware,
                    target.BookingTicketId,
                    lastStartedAt,
                    isActive,
                    isActive && _activeEntry?.Status == WorkEntryStatus.Paused,
                    todayDuration);
            })
            .OrderByDescending(task => task.IsActive)
            .ThenByDescending(task => task.LastStartedAt.HasValue)
            .ThenByDescending(task => task.LastStartedAt)
            .ThenBy(task => task.CustomerName)
            .ThenBy(task => task.Name)
            .ToList();
    }

    private void ShowAllTasks()
    {
        _showAllTasks = true;
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return $"{(int)duration.TotalHours:00}:{duration.Minutes:00}:{duration.Seconds:00}";
    }

    private static string FormatDayLabel(DateTime date)
    {
        return date.DayOfWeek switch
        {
            DayOfWeek.Monday => "Mo",
            DayOfWeek.Tuesday => "Tu",
            DayOfWeek.Wednesday => "We",
            DayOfWeek.Thursday => "Th",
            DayOfWeek.Friday => "Fr",
            DayOfWeek.Saturday => "Sa",
            _ => "Su"
        };
    }

    private static DateTime GetStartOfWeek(DateTime date)
    {
        var daysSinceMonday = ((int)date.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        return date.Date.AddDays(-daysSinceMonday);
    }

    private TimeSpan SumNetDuration(IEnumerable<WorkEntry> entries, DateTime now)
    {
        return entries.Aggregate(TimeSpan.Zero, (total, entry) => total + TimeTracking.GetNetDuration(entry, now));
    }

    private static string FormatTaskMeta(QuickTaskItem task)
    {
        return $"{task.CustomerName} - {task.BookingSoftware} {task.BookingTicketId}";
    }

    private static string FormatEntryWork(WorkEntry entry)
    {
        return entry.ProjectTask?.Title
            ?? entry.BookingTarget?.Name
            ?? entry.Project?.Name
            ?? entry.ActivityCategory?.Name
            ?? entry.Description
            ?? "Custom tracking";
    }

    private static string FormatEntryTime(WorkEntry entry)
    {
        var stop = entry.StoppedAt?.ToString("HH:mm") ?? "now";
        return $"{entry.StartedAt:HH:mm} - {stop}";
    }

    private string GetTaskActionLabel(QuickTaskItem task)
    {
        if (task.IsPaused)
        {
            return "Resume";
        }

        if (task.IsActive)
        {
            return "Tracking";
        }

        return _activeEntry is null ? "Start" : "Switch";
    }

    private static Variant GetQuickTaskVariant(QuickTaskItem task)
    {
        return task.IsActive ? Variant.Filled : Variant.Outlined;
    }

    private static Color GetQuickTaskColor(QuickTaskItem task)
    {
        return task.IsActive || task.IsPaused ? Color.Primary : Color.Default;
    }

    private static string GetQuickTaskClass(QuickTaskItem task)
    {
        var cssClass = "wock-quick-task";
        if (task.IsPaused)
        {
            cssClass += " wock-quick-task-paused";
        }

        return cssClass;
    }

    private void StartLiveRefresh()
    {
        _liveRefreshCancellation = new CancellationTokenSource();
        _liveRefreshTask = RunLiveRefreshAsync(_liveRefreshCancellation.Token);
    }

    private async Task RunLiveRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(RefreshLiveTrackingAsync);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task RefreshLiveTrackingAsync()
    {
        var now = Clock.UtcNow;
        var crossedDateBoundary = now.Date != _todayStart || GetStartOfWeek(now.Date) != _weekStart;
        var hasRunningEntry = _activeEntry?.Status == WorkEntryStatus.Running;
        if (!crossedDateBoundary && !hasRunningEntry)
        {
            return;
        }

        if (!_isBusy && crossedDateBoundary)
        {
            await RefreshAsync();
        }
        else
        {
            RefreshLiveDurations(now);
        }

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_liveRefreshCancellation is null)
        {
            return;
        }

        await _liveRefreshCancellation.CancelAsync();
        if (_liveRefreshTask is not null)
        {
            await _liveRefreshTask;
        }

        _liveRefreshCancellation.Dispose();
    }

    private sealed record QuickTaskItem(
        int Id,
        string CustomerName,
        string Name,
        string BookingSoftware,
        string BookingTicketId,
        DateTime? LastStartedAt,
        bool IsActive,
        bool IsPaused,
        TimeSpan TodayDuration)
    {
        public bool Matches(string search)
        {
            return Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                || CustomerName.Contains(search, StringComparison.OrdinalIgnoreCase)
                || BookingSoftware.Contains(search, StringComparison.OrdinalIgnoreCase)
                || BookingTicketId.Contains(search, StringComparison.OrdinalIgnoreCase);
        }
    }
}
