@using Microsoft.AspNetCore.Components.Forms
@using Wock.Models

<EditForm Model="_model" OnValidSubmit="SubmitAsync">
    <MudStack Spacing="2">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudSelect T="int" Label="Customer" Value="@_model.CustomerId" ValueChanged="CustomerChanged" Disabled="@Disabled" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">Select a customer</MudSelectItem>
                    @foreach (var customer in Customers)
                    {
                        <MudSelectItem T="int" Value="@customer.Id">@customer.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?" Label="Project" Value="@_model.ProjectId" ValueChanged="ProjectChanged" Disabled="@Disabled" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var project in AvailableProjects)
                    {
                        <MudSelectItem T="int?" Value="@project.Id">@project.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?" Label="Activity" @bind-Value="_model.ActivityCategoryId" Disabled="@Disabled" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var category in ActivityCategories.Where(category => category.IsActive).OrderBy(category => category.SortOrder))
                    {
                        <MudSelectItem T="int?" Value="@category.Id">@category.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?" Label="Project task" @bind-Value="_model.ProjectTaskId" Disabled="@Disabled" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var task in AvailableProjectTasks)
                    {
                        <MudSelectItem T="int?" Value="@task.Id">@task.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?" Label="Recent preset" @bind-Value="_model.BookingTargetId" Disabled="@Disabled" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var target in AvailableBookingTargets)
                    {
                        <MudSelectItem T="int?" Value="@target.Id">@target.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField T="string" Label="External ticket" @bind-Value="_model.ExternalTicketId" Disabled="@Disabled" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField T="string" Label="Description" Lines="3" @bind-Value="_model.Description" Disabled="@Disabled" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12">
                <MudCheckBox T="bool" Label="Billable" @bind-Value="_model.IsBillable" Disabled="@Disabled" Color="Color.Primary" />
            </MudItem>
        </MudGrid>

        <StatusMessage Message="@_message" Kind="@Severity.Warning" />

        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(Disabled || !Customers.Any())">Start tracking</MudButton>
    </MudStack>
</EditForm>

@code {
    private readonly FormModel _model = new();
    private string? _message;

    [Parameter]
    public IEnumerable<Customer> Customers { get; set; } = [];

    [Parameter]
    public IEnumerable<BookingTarget> BookingTargets { get; set; } = [];

    [Parameter]
    public IEnumerable<Project> Projects { get; set; } = [];

    [Parameter]
    public IEnumerable<ProjectTask> ProjectTasks { get; set; } = [];

    [Parameter]
    public IEnumerable<ActivityCategory> ActivityCategories { get; set; } = [];

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<StartWorkEntryRequest> OnStart { get; set; }

    private IEnumerable<BookingTarget> AvailableBookingTargets => BookingTargets
        .Where(target => _model.CustomerId == 0 || target.CustomerId == _model.CustomerId);

    private IEnumerable<Project> AvailableProjects => Projects
        .Where(project => _model.CustomerId == 0 || project.CustomerId == _model.CustomerId)
        .Where(project => project.Status is not ProjectStatus.Archived);

    private IEnumerable<ProjectTask> AvailableProjectTasks => ProjectTasks
        .Where(task => _model.CustomerId == 0 || task.Project.CustomerId == _model.CustomerId)
        .Where(task => _model.ProjectId is null || task.ProjectId == _model.ProjectId)
        .Where(task => task.Status is not ProjectTaskStatus.Archived);

    private void CustomerChanged(int customerId)
    {
        _model.CustomerId = customerId;
        if (_model.ProjectId is not null && !AvailableProjects.Any(project => project.Id == _model.ProjectId.Value))
        {
            _model.ProjectId = null;
            _model.ProjectTaskId = null;
        }
    }

    private void ProjectChanged(int? projectId)
    {
        _model.ProjectId = projectId;
        if (_model.ProjectTaskId is not null && !AvailableProjectTasks.Any(task => task.Id == _model.ProjectTaskId.Value))
        {
            _model.ProjectTaskId = null;
        }
    }

    private async Task SubmitAsync()
    {
        if (_model.CustomerId <= 0)
        {
            _message = "Choose an active customer before starting time tracking.";
            return;
        }

        _message = null;
        await OnStart.InvokeAsync(new StartWorkEntryRequest(
            _model.CustomerId,
            _model.BookingTargetId,
            _model.ExternalTicketId,
            _model.Description,
            _model.ProjectId,
            _model.ProjectTaskId,
            _model.ActivityCategoryId,
            _model.IsBillable));
        _model.BookingTargetId = null;
        _model.ProjectId = null;
        _model.ProjectTaskId = null;
        _model.ActivityCategoryId = null;
        _model.ExternalTicketId = null;
        _model.Description = null;
        _model.IsBillable = true;
    }

    private sealed class FormModel
    {
        public int CustomerId { get; set; }

        public int? BookingTargetId { get; set; }

        public int? ProjectId { get; set; }

        public int? ProjectTaskId { get; set; }

        public int? ActivityCategoryId { get; set; }

        public string? ExternalTicketId { get; set; }

        public string? Description { get; set; }

        public bool IsBillable { get; set; } = true;
    }
}
