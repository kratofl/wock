@using Wock.Models

@if (Entry is null)
{
    <MudCard Elevation="0" Outlined="true" Class="wock-data-panel wock-active-timer">
        <MudCardContent>
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Class="wock-metric-label">Current tracking</MudText>
                <MudText Typo="Typo.h5">Ready to track</MudText>
                <MudText Typo="Typo.body2" Class="wock-muted">Choose a task to start tracking instantly.</MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>
}
else
{
    <MudCard Elevation="0" Outlined="true" Class="wock-data-panel wock-active-timer">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.overline" Class="wock-metric-label">Current tracking</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@Entry.Status</MudChip>
                </MudStack>
                <MudText Typo="Typo.h3" Class="wock-active-duration">@FormatDuration(NetDuration)</MudText>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@CurrentTaskName</MudText>
                    <MudText Typo="Typo.body2" Class="wock-muted">@Entry.Customer?.Name</MudText>
                </MudStack>
                <MudGrid Spacing="2">
                    @if (!string.IsNullOrWhiteSpace(Entry.ExternalTicketId))
                    {
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.overline" Class="wock-metric-label">External ticket</MudText>
                            <MudText Typo="Typo.body1">@Entry.ExternalTicketId</MudText>
                        </MudItem>
                    }
                    @if (!string.IsNullOrWhiteSpace(Entry.Description))
                    {
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.overline" Class="wock-metric-label">Description</MudText>
                            <MudText Typo="Typo.body1">@Entry.Description</MudText>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudCardContent>
        <MudCardActions Class="wock-panel-actions">
            @if (Entry.Status == WorkEntryStatus.Running)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="Disabled" OnClick="OnPause">Pause</MudButton>
            }
            else if (Entry.Status == WorkEntryStatus.Paused)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="Disabled" OnClick="OnResume">Resume</MudButton>
            }

            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="Disabled" OnClick="OnStop">Stop</MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    [Parameter]
    public WorkEntry? Entry { get; set; }

    [Parameter]
    public TimeSpan NetDuration { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback OnPause { get; set; }

    [Parameter]
    public EventCallback OnResume { get; set; }

    [Parameter]
    public EventCallback OnStop { get; set; }

    private string CurrentTaskName => Entry?.BookingTarget?.Name
        ?? Entry?.Description
        ?? "Custom tracking";

    private static string FormatDuration(TimeSpan duration)
    {
        return $"{(int)duration.TotalHours:00}:{duration.Minutes:00}:{duration.Seconds:00}";
    }
}
