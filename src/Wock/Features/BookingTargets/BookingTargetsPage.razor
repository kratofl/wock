@page "/booking-targets"
@using Wock.Features.Customers
@using Wock.Models
@inject CustomerService CustomerService
@inject BookingTargetService BookingTargetService

<MudStack Spacing="3" Class="wock-page-stack">
    <MudText Typo="Typo.h3">Tasks</MudText>

    <StatusMessage Message="@_message" Kind="@_messageSeverity" />

    <MudSelect T="int?" Label="Customer" Value="@_selectedCustomerId" ValueChanged="CustomerChangedAsync" Variant="Variant.Outlined" Margin="Margin.Dense">
        @foreach (var customer in _customers)
        {
            <MudSelectItem T="int?" Value="@customer.Id">@customer.Name</MudSelectItem>
        }
    </MudSelect>

    @if (_selectedCustomerId is null)
    {
        <MudText>Create an active customer before managing tasks.</MudText>
    }
    else
    {
        <MudPaper Elevation="0" Class="wock-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h5">Create task</MudText>
                    <MudTextField T="string" Label="Name" @bind-Value="_newTarget.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField T="string" Label="Booking system" @bind-Value="_newTarget.BookingSoftware" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField T="string" Label="Booking reference" @bind-Value="_newTarget.BookingTicketId" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudTextField T="string" Label="Notes" Lines="3" @bind-Value="_newTarget.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync">Create task</MudButton>
            </MudStack>
        </MudPaper>

        <MudText Typo="Typo.h5">Active tasks</MudText>

        @if (_targets.Count == 0)
        {
            <MudText>No active tasks for this customer.</MudText>
        }
        else
        {
            <MudTable Items="_targets" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Booking system</MudTh>
                    <MudTh>Booking reference</MudTh>
                    <MudTh>Notes</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate Context="target">
                    @{
                        var model = _editModels[target.Id];
                    }
                    <MudTd DataLabel="Name">
                        <MudTextField T="string" aria-label="Task name" @bind-Value="model.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd DataLabel="Booking system">
                        <MudTextField T="string" aria-label="Booking system" @bind-Value="model.BookingSoftware" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd DataLabel="Booking reference">
                        <MudTextField T="string" aria-label="Booking reference" @bind-Value="model.BookingTicketId" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd DataLabel="Notes">
                        <MudTextField T="string" aria-label="Task notes" @bind-Value="model.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        <div class="wock-button-row">
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="() => UpdateAsync(target.Id)">Save</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeactivateAsync(target.Id)">Deactivate</MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
</MudStack>

@code {
    private readonly BookingTargetFormModel _newTarget = new();
    private readonly Dictionary<int, BookingTargetFormModel> _editModels = [];
    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<BookingTarget> _targets = [];
    private int? _selectedCustomerId;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.ListActiveAsync();
        _selectedCustomerId = _customers.FirstOrDefault()?.Id;
        await RefreshTargetsAsync();
    }

    private async Task CustomerChangedAsync(int? customerId)
    {
        _selectedCustomerId = customerId;
        await RefreshTargetsAsync();
    }

    private async Task CreateAsync()
    {
        if (_selectedCustomerId is null)
        {
            _message = "An active customer is required before creating a task.";
            _messageSeverity = Severity.Warning;
            return;
        }

        try
        {
            await BookingTargetService.CreateAsync(
                _selectedCustomerId.Value,
                _newTarget.Name,
                _newTarget.BookingSoftware,
                _newTarget.BookingTicketId,
                _newTarget.Notes);
            _newTarget.Name = string.Empty;
            _newTarget.BookingSoftware = string.Empty;
            _newTarget.BookingTicketId = string.Empty;
            _newTarget.Notes = string.Empty;
            _message = "Task created.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshTargetsAsync();
    }

    private async Task UpdateAsync(int targetId)
    {
        try
        {
            var model = _editModels[targetId];
            await BookingTargetService.UpdateAsync(
                _selectedCustomerId!.Value,
                targetId,
                model.Name,
                model.BookingSoftware,
                model.BookingTicketId,
                model.Notes);
            _message = "Task updated.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshTargetsAsync();
    }

    private async Task DeactivateAsync(int targetId)
    {
        try
        {
            await BookingTargetService.DeactivateAsync(_selectedCustomerId!.Value, targetId);
            _message = "Task deactivated.";
            _messageSeverity = Severity.Success;
        }
        catch (Exception exception)
        {
            _message = exception.Message;
            _messageSeverity = Severity.Error;
        }

        await RefreshTargetsAsync();
    }

    private async Task RefreshTargetsAsync()
    {
        _targets = _selectedCustomerId is null
            ? []
            : await BookingTargetService.ListActiveForCustomerAsync(_selectedCustomerId.Value);
        _editModels.Clear();
        foreach (var target in _targets)
        {
            _editModels[target.Id] = new BookingTargetFormModel
            {
                Name = target.Name,
                BookingSoftware = target.BookingSoftware,
                BookingTicketId = target.BookingTicketId,
                Notes = target.Notes ?? string.Empty
            };
        }
    }

    private sealed class BookingTargetFormModel
    {
        public string Name { get; set; } = string.Empty;

        public string BookingSoftware { get; set; } = string.Empty;

        public string BookingTicketId { get; set; } = string.Empty;

        public string Notes { get; set; } = string.Empty;
    }
}
