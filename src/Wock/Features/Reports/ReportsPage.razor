@page "/reports"
@using System.Globalization
@using Wock.Models
@inject ReportService ReportService

<MudStack Spacing="3" Class="wock-page-stack">
    <MudText Typo="Typo.h3">Reports</MudText>

    <StatusMessage Message="@_message" Kind="@_messageSeverity" />

    <MudPaper Elevation="0" Class="wock-section">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h5">Filters</MudText>
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="From" Date="@FromDateValue" DateChanged="FromDateChanged" DateFormat="yyyy-MM-dd" FirstDayOfWeek="DayOfWeek.Monday" AutoClose="true" PickerVariant="PickerVariant.Dialog" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="To" Date="@ToDateValue" DateChanged="ToDateChanged" DateFormat="yyyy-MM-dd" FirstDayOfWeek="DayOfWeek.Monday" AutoClose="true" PickerVariant="PickerVariant.Dialog" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="int?" Label="Customer" Value="@_selectedCustomerId" ValueChanged="CustomerChanged" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var customer in _customers)
                        {
                            <MudSelectItem T="int?" Value="@customer.Id">@customer.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="int?" Label="Task" Value="@_selectedBookingTargetId" ValueChanged="TaskChanged" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var task in AvailableTasks)
                        {
                            <MudSelectItem T="int?" Value="@task.Id">@FormatTaskOption(task)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField T="string" Label="External ticket" Value="@_externalTicketId" ValueChanged="ExternalTicketChanged" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="wock-button-row">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadReportAsync">Apply filters</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsvAsync">Export CSV</MudButton>
                        @if (_csvDownloadUrl is not null)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default" Href="@_csvDownloadUrl" download="wock-report.csv">Download CSV</MudButton>
                        }
                    </div>
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1">Booking connectors</MudText>
                    @if (_bookingConnectors.Count == 0)
                    {
                        <MudText Class="wock-muted">No enabled booking connectors.</MudText>
                    }
                    else
                    {
                        <MudList T="string" Dense="true">
                            @foreach (var connector in _bookingConnectors)
                            {
                                <MudListItem>@connector.Name (@connector.Version)</MudListItem>
                            }
                        </MudList>
                    }
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>

    <MudTable Items="_rows" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Customer</MudTh>
            <MudTh>Task</MudTh>
            <MudTh>Reference</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Time</MudTh>
            <MudTh>Paused</MudTh>
            <MudTh>Net</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Date">@context.Date.ToString("yyyy-MM-dd")</MudTd>
            <MudTd DataLabel="Customer">@context.CustomerName</MudTd>
            <MudTd DataLabel="Task">@FormatTaskName(context)</MudTd>
            <MudTd DataLabel="Reference">
                <MudStack Spacing="1">
                    @if (HasBookingReference(context))
                    {
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Booking</MudChip>
                            <MudText Typo="Typo.body2">@FormatBookingReference(context)</MudText>
                        </MudStack>
                    }
                    @if (!string.IsNullOrWhiteSpace(context.ExternalReference))
                    {
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">External</MudChip>
                            <MudText Typo="Typo.body2">@context.ExternalReference</MudText>
                        </MudStack>
                    }
                    @if (!HasBookingReference(context) && string.IsNullOrWhiteSpace(context.ExternalReference))
                    {
                        <MudText Typo="Typo.body2" Class="wock-muted">No reference</MudText>
                    }
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Description">@(context.Description ?? string.Empty)</MudTd>
            <MudTd DataLabel="Time">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body2">@FormatClock(context.Start) - @FormatClock(context.Stop)</MudText>
                    @if (context.Start.Date != context.Stop.Date)
                    {
                        <MudText Typo="Typo.caption" Class="wock-muted">@FormatDateTime(context.Stop)</MudText>
                    }
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Paused">@FormatDuration(context.PauseDuration)</MudTd>
            <MudTd DataLabel="Net">@FormatDuration(context.NetDuration)</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No stopped work entries match the selected filters.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudStack>

@code {
    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<BookingTarget> _bookingTargets = [];
    private IReadOnlyList<Wock.Abstractions.WockPluginMetadata> _bookingConnectors = [];
    private IReadOnlyList<ReportRow> _rows = [];
    private DateOnly _fromDate = DateOnly.FromDateTime(DateTime.UtcNow.Date.AddDays(-30));
    private DateOnly _toDate = DateOnly.FromDateTime(DateTime.UtcNow.Date);
    private int? _selectedCustomerId = null;
    private int? _selectedBookingTargetId = null;
    private string? _externalTicketId = null;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;
    private string? _csvDownloadUrl;

    private DateTime? FromDateValue => _fromDate.ToDateTime(TimeOnly.MinValue);

    private DateTime? ToDateValue => _toDate.ToDateTime(TimeOnly.MinValue);

    private IReadOnlyList<BookingTarget> AvailableTasks => _selectedCustomerId is null
        ? _bookingTargets
        : _bookingTargets
            .Where(task => task.CustomerId == _selectedCustomerId.Value)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var options = await ReportService.GetFilterOptionsAsync();
        _customers = options.Customers;
        _bookingTargets = options.BookingTargets;
        _bookingConnectors = options.BookingConnectors;
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        if (_fromDate > _toDate)
        {
            _message = "From date must be on or before To date.";
            _messageSeverity = Severity.Warning;
            _rows = [];
            _csvDownloadUrl = null;
            return;
        }

        _rows = await ReportService.GetReportAsync(CurrentFilter());
        _message = null;
        _csvDownloadUrl = null;
    }

    private async Task ExportCsvAsync()
    {
        await LoadReportAsync();

        if (!string.IsNullOrWhiteSpace(_message))
        {
            return;
        }

        var csv = ReportService.ExportCsv(_rows);
        _csvDownloadUrl = $"data:text/csv;charset=utf-8,{Uri.EscapeDataString(csv)}";
        _message = "CSV export is ready.";
        _messageSeverity = Severity.Success;
    }

    private ReportFilter CurrentFilter()
    {
        return new ReportFilter(
            _fromDate,
            _toDate,
            _selectedCustomerId,
            _selectedBookingTargetId,
            _externalTicketId);
    }

    private void FromDateChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _fromDate = DateOnly.FromDateTime(value.Value);
        }
    }

    private void ToDateChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _toDate = DateOnly.FromDateTime(value.Value);
        }
    }

    private void CustomerChanged(int? customerId)
    {
        _selectedCustomerId = customerId;
        if (_selectedBookingTargetId is not null && !AvailableTasks.Any(task => task.Id == _selectedBookingTargetId))
        {
            _selectedBookingTargetId = null;
        }
    }

    private void TaskChanged(int? bookingTargetId)
    {
        _selectedBookingTargetId = bookingTargetId;
        if (bookingTargetId is null)
        {
            return;
        }

        var task = _bookingTargets.SingleOrDefault(task => task.Id == bookingTargetId.Value);
        if (task is not null)
        {
            _selectedCustomerId = task.CustomerId;
        }
    }

    private void ExternalTicketChanged(string? externalTicketId)
    {
        _externalTicketId = externalTicketId;
    }

    private static string FormatTaskOption(BookingTarget task)
    {
        return $"{task.Customer.Name} - {task.Name}";
    }

    private static string FormatTaskName(ReportRow row)
    {
        return row.TaskName ?? "Custom tracking";
    }

    private static bool HasBookingReference(ReportRow row)
    {
        return !string.IsNullOrWhiteSpace(row.BookingSystem)
            || !string.IsNullOrWhiteSpace(row.BookingReference);
    }

    private static string FormatBookingReference(ReportRow row)
    {
        if (string.IsNullOrWhiteSpace(row.BookingSystem))
        {
            return row.BookingReference ?? string.Empty;
        }

        if (string.IsNullOrWhiteSpace(row.BookingReference))
        {
            return row.BookingSystem;
        }

        return $"{row.BookingSystem} {row.BookingReference}";
    }

    private static string FormatClock(DateTime value)
    {
        return value.ToString("HH:mm:ss", CultureInfo.InvariantCulture);
    }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture);
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return $"{(int)duration.TotalHours:00}:{duration.Minutes:00}:{duration.Seconds:00}";
    }
}
